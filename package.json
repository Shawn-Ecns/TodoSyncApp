{
  "name": "todo-sync",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@todo-sync/web",
    "dev:server": "turbo run dev --filter=@todo-sync/server",
    "dev:mobile": "turbo run dev --filter=@todo-sync/mobile",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @todo-sync/server prisma migrate dev",
    "db:generate": "pnpm --filter @todo-sync/server prisma generate"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.7"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  }
}
